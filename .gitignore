# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]

# C extensions
*.so

# Distribution / packaging
.Python
env/
myenv/
my_env/
venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover

# Translations
*.mo
*.pot

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# DotEnv configuration
.env

# Database
*.db
*.rdb

# Pycharm
.idea

# VS Code
.vscode/

# Spyder
.spyproject/

# Jupyter NB Checkpoints
.ipynb_checkpoints/

# exclude raw data from source control — DVC pointer files (.dvc) are tracked instead
/data/**/*.csv
/data/**/*.parquet
/data/**/*.pkl
/data/**/*.joblib

# Mac OS-specific storage files
.DS_Store

# vim
*.swp
*.swo

# Mypy cache
.mypy_cache/
*.joblib
volumes/
*.pptx

# Drift reports (generated by Evidently — reproduits à chaque cycle de training)
reports/drift/*
!reports/drift/.gitkeep

# Kapsule runtime state (IPs dynamiques — générées par kapsule-up.yml)
state/*
!state/.gitkeep

# MLflow local tracking (source de vérité = MLflow Server VPS)
mlruns/

# Modèle binaire local (source de vérité = MLflow Registry @Production)
src/models/trained_model.joblib

# Claude Code — permissions personnelles (pas partagées avec les autres contributeurs)
.claude/settings.local.json
