{
  "title": "cac-mlops — Model Drift",
  "uid": "cac-mlops-drift",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Niveau de drift",
      "description": "0=OK · 1=WARNING · 2=CRITICAL",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "cac_mlops_drift_level",
        "legendFormat": "niveau"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "OK",       "color": "green"  } } },
          { "type": "value", "options": { "1": { "text": "WARNING",  "color": "yellow" } } },
          { "type": "value", "options": { "2": { "text": "CRITICAL", "color": "red"    } } }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Drift share (%)",
      "description": "Part des features ayant drifté vs référence entraînement",
      "gridPos": { "x": 4, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "cac_mlops_drift_share * 100",
        "legendFormat": "drift %"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Features driftées",
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "cac_mlops_drift_drifted_count",
        "legendFormat": "driftées"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 7 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Features totales surveillées",
      "gridPos": { "x": 14, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "cac_mlops_drift_total_features",
        "legendFormat": "total"
      }],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Dernier rapport drift",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "cac_mlops_drift_report_timestamp * 1000",
        "legendFormat": "timestamp"
      }],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Drift share — évolution",
      "description": "Évolution du pourcentage de features driftées au fil du temps",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "cac_mlops_drift_share * 100",
        "legendFormat": "drift %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 25 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Drift level — évolution",
      "description": "0=OK · 1=WARNING · 2=CRITICAL",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "cac_mlops_drift_level",
        "legendFormat": "niveau"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Score de drift par feature",
      "description": "Score statistique Evidently par feature (plus élevé = plus drifté). Seuil détection ≈ 0.05 selon le test utilisé.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "targets": [{
        "expr": "sort_desc(cac_mlops_drift_feature_score)",
        "legendFormat": "{{ feature }}"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.25 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ]
}
