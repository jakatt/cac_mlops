        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-k8s"},
          "expr": "kube_deployment_status_replicas_available{namespace=\"cac-mlops\", deployment=~\"api|gradio|gradio-public\"}",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "title": "Replicas disponibles par Deployment — preuve du zero-downtime pendant un rollout",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-k8s"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "stepped": true
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "id": 2,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-k8s"},
          "expr": "probe_success{instance=\"https://kapsule.jakat-inc.fr/health\"}",
          "legendFormat": "endpoint public",
          "refId": "A"
        }
      ],
      "title": "Sonde publique (blackbox) — chemin caddy → nginx → api",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-k8s"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
