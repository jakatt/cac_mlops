  "version": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-k8s"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "stepped": true
          },
          "min": 0,
          "unit": "short"
