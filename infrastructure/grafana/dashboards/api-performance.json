{
  "title": "cac-mlops — API Performance",
  "uid": "cac-mlops-api",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requêtes /predict (total)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(api_predictions_total)",
        "legendFormat": "total"
      }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Taux erreurs 5xx (1m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(api_requests_total{status=~\"5..\"}[1m])) / sum(rate(api_requests_total[1m])) * 100",
        "legendFormat": "% erreurs"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": null, "color": "green" },
            { "value": 1, "color": "yellow" },
            { "value": 5, "color": "red" }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latence p95 /predict (1m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{endpoint=\"/predict\"}[1m])) by (le))",
        "legendFormat": "p95"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": null, "color": "green" },
            { "value": 0.1, "color": "yellow" },
            { "value": 0.3, "color": "red" }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "% prédictions prioritaires (grav=1)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(api_predictions_total{result=\"1\"}) / sum(api_predictions_total) * 100",
        "legendFormat": "% grav=1"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requêtes par seconde",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(api_requests_total{status=\"429\"}[1m]))",
          "legendFormat": "429 (rate limit)"
        },
        {
          "expr": "sum(rate(api_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latence /predict (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Distribution prédictions (grav=0 vs grav=1)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(api_predictions_total{result=\"0\"}[5m])",
          "legendFormat": "grav=0 (non prioritaire)"
        },
        {
          "expr": "rate(api_predictions_total{result=\"1\"}[5m])",
          "legendFormat": "grav=1 (prioritaire)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requêtes par endpoint",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (endpoint) (rate(api_requests_total[5m]))",
        "legendFormat": "{{endpoint}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
