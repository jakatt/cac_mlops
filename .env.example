# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copier en .env et adapter selon votre contexte
# NE JAMAIS commiter .env (il est dans .gitignore)
# ══════════════════════════════════════════════════════════════════════════════

# ── MODE : choisir l'un des deux blocs ci-dessous ────────────────────────────

# ── MODE A : Accès via Tailscale VPN (recommandé en équipe) ─────────────────
# Prérequis : installer Tailscale sur ton Mac (tailscale.com/download)
# puis être accepté dans le tailnet par l'admin.
# Remplace VPS_TAILSCALE_IP par l'IP Tailscale du VPS (ex: 100.64.x.x)
# Visible dans la console Tailscale ou via `tailscale ip -4` sur le VPS.
#
MLFLOW_TRACKING_URI=http://VPS_TAILSCALE_IP:5001
MLFLOW_S3_ENDPOINT_URL=http://VPS_TAILSCALE_IP:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── MODE B : MLflow local isolé (sans tunnel, expériences non partagées) ─────
# docker compose up -d mlflow minio postgresql
# Les runs restent locaux — non visibles par l'équipe
#
# MLFLOW_TRACKING_URI=http://localhost:5001
# MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlops

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── API JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-change-in-production
API_USERNAME=admin
API_PASSWORD=changeme

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Grafana SMTP (alertes email) — générer un App Password Gmail ─────────────
# https://myaccount.google.com/apppasswords
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=jacques.cattelin@gmail.com
GF_SMTP_PASSWORD=<app-password-gmail>
GF_SMTP_FROM_ADDRESS=grafana@cac-mlops.fr
GF_ALERT_EMAIL=jacques.cattelin@gmail.com

# ── Scaleway Object Storage — DVC remote (données brutes versionnées) ────────
# Clés IAM Scaleway avec accès au bucket cac-mlops-data
# Récupérer dans la console Scaleway → IAM → API Keys
# En local : ces valeurs sont aussi dans .dvc/config.local (ne pas commiter)
SCW_ACCESS_KEY_ID=YOUR_SCALEWAY_ACCESS_KEY
SCW_SECRET_ACCESS_KEY=YOUR_SCALEWAY_SECRET_KEY


# ── Kapsule K8s — Phase 5 ────────────────────────────────────────────────────
# Récupérer dans la console Scaleway → Kubernetes → <cluster> → Informations
KAPSULE_CLUSTER_ID=<votre-cluster-id>
# Récupérer dans Scaleway → IAM → Organisations
SCW_DEFAULT_ORGANIZATION_ID=<votre-org-id>

# ── Tailscale — IP privée du VPS dans le tailnet ─────────────────────────────
# Renseigné automatiquement par infrastructure/tailscale/setup.sh sur le VPS.
# Sur le VPS : les ports admin Docker se lient à cette IP (inaccessibles depuis internet).
# Sur une machine locale : laisser vide (les ports se lient à 127.0.0.1).
# VPS_TAILSCALE_IP=100.64.x.x

# ── Docker volumes (laisser vide en local, /data en prod VPS) ────────────────
# DOCKER_VOLUMES_PATH=/data   # décommenté automatiquement par deploy.yml sur VPS
